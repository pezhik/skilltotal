# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
*.egg

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/

# Editors / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Secrets / credentials — never commit (also enforced by secret scanning, see SECURITY.md)
.env
.env.*
*.env
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*
*.token
.pypirc
.npmrc
credentials.json
secrets.json
*.secret

# SkillTotal output artifacts
report.json
*.sarif

# Real-world evaluation corpus (cloned third-party repos; reproduce via fetch_corpus.py)
tests/manual_eval/corpus/

# Local calibration scratch output (run via tests/manual_eval/calibrate.py)
/calib_*

# Stray JS tooling must never land in this zero-dep Python engine
node_modules/
package.json
package-lock.json
# ...but test fixtures legitimately ship a package.json/lock to exercise npm detection.
!tests/**/package.json
!tests/**/package-lock.json

# Stray local SQLite DBs from local integration runs (not part of the engine)
_test_web.db
_dev_web.db
local_e2e.db

# Local-only superpowers planning docs (specs/plans) — must never reach the public repo.
docs/superpowers/
