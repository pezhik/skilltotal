{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skilltotal.dev/schemas/report-1.5.json",
  "title": "SkillTotal Report",
  "description": "Machine-readable contract for skilltotal.models.Report.to_dict(). Report schema version 1.5 (1.4 + traits: a behavioral trait fingerprint with a CSA/MAESTRO/ATLAS crosswalk, descriptive only and never scored). Consumers (e.g. the web app) should validate against this; a breaking change here corresponds to a major engine version bump.",
  "type": "object",
  "required": [
    "component",
    "risk_score",
    "risk_level",
    "summary",
    "verdict",
    "capabilities",
    "traits",
    "findings",
    "needs_review",
    "metadata"
  ],
  "additionalProperties": false,
  "properties": {
    "component": {
      "type": "object",
      "required": ["name", "type", "source", "version"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "source": { "type": "string" },
        "version": { "type": "string" },
        "download_url": {
          "type": ["string", "null"],
          "description": "Distribution artifact fetched for package sources (npm/PyPI); null for git/local (added in 1.2)."
        }
      }
    },
    "risk_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "risk_level": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "summary": { "type": "string" },
    "verdict": {
      "type": "object",
      "description": "Plain-language top-line answer, independent of risk_score (added in 1.3).",
      "required": ["has_malicious_indicators", "level", "headline"],
      "additionalProperties": true,
      "properties": {
        "level": {
          "type": "string",
          "enum": ["malicious", "critical", "high", "medium", "low"]
        },
        "headline": { "type": "string" },
        "has_malicious_indicators": { "type": "boolean" },
        "reasons": { "type": "array", "items": { "type": "string" } },
        "malicious_indicators": { "type": "integer", "minimum": 0 },
        "risky_constructs": { "type": "integer", "minimum": 0 },
        "capabilities": { "type": "integer", "minimum": 0 }
      }
    },
    "capabilities": {
      "type": "object",
      "description": "Capability name -> list of evidence proving it.",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/$defs/evidence" }
      }
    },
    "traits": {
      "type": "array",
      "description": "Behavioral trait fingerprint with a CSA/MAESTRO/ATLAS crosswalk. Descriptive only; never affects the score (added in 1.5).",
      "items": { "$ref": "#/$defs/trait" }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "needs_review": {
      "type": "array",
      "items": { "$ref": "#/$defs/needs_review" }
    },
    "metadata": {
      "type": "object",
      "description": "Run metadata. Known keys below; additional keys are allowed for forward compatibility.",
      "properties": {
        "skilltotal_version": { "type": "string" },
        "schema_version": { "type": "string" },
        "ruleset_version": { "type": "integer" },
        "generated_at": { "type": "string" },
        "files_indexed": { "type": "integer" },
        "files_skipped_binary": { "type": "integer" },
        "files_skipped_large": { "type": "integer" },
        "scanners_run": { "type": "array", "items": { "type": "string" } },
        "findings_by_severity": { "type": "object" },
        "suppressed_count": { "type": "integer" }
      },
      "required": ["skilltotal_version", "schema_version", "ruleset_version"],
      "additionalProperties": true
    }
  },
  "$defs": {
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "evidence": {
      "type": "object",
      "description": "A concrete anchor for a finding. Every confirmed finding has at least one.",
      "required": ["file", "line_start", "line_end", "snippet"],
      "additionalProperties": false,
      "properties": {
        "file": { "type": "string" },
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 },
        "snippet": { "type": "string" }
      }
    },
    "finding": {
      "type": "object",
      "required": [
        "id",
        "severity",
        "category",
        "title",
        "description",
        "evidence",
        "recommendation",
        "threat_class",
        "owasp"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "severity": { "$ref": "#/$defs/severity" },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        },
        "recommendation": { "type": "string" },
        "threat_class": {
          "type": "string",
          "enum": ["malicious_indicator", "risky_construct", "capability"],
          "description": "Reading axis next to severity (added in 1.3)."
        },
        "owasp": {
          "type": "array",
          "description": "OWASP Agentic Skills Top 10 category ids for this rule; empty when there is no honest static fit. Never affects the score (added in 1.4).",
          "items": {
            "type": "string",
            "enum": [
              "AST01",
              "AST02",
              "AST03",
              "AST04",
              "AST05",
              "AST06",
              "AST07",
              "AST08",
              "AST09",
              "AST10"
            ]
          }
        }
      }
    },
    "trait": {
      "type": "object",
      "description": "One exhibited behavioral trait plus its standards crosswalk and backing evidence.",
      "required": [
        "trait",
        "title",
        "description",
        "emergent",
        "crosswalk",
        "evidence"
      ],
      "additionalProperties": false,
      "properties": {
        "trait": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "emergent": {
          "type": "boolean",
          "description": "True for combination traits backed by a synthesized risky-construct finding."
        },
        "crosswalk": {
          "type": "object",
          "required": ["csa_trait", "csa_risk", "maestro_layers", "atlas_tactics"],
          "additionalProperties": false,
          "properties": {
            "csa_trait": { "type": "string" },
            "csa_risk": { "type": "string" },
            "maestro_layers": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "name"],
                "additionalProperties": false,
                "properties": {
                  "id": { "type": "string" },
                  "name": { "type": "string" }
                }
              }
            },
            "atlas_tactics": { "type": "array", "items": { "type": "string" } }
          }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "needs_review": {
      "type": "object",
      "required": ["category", "title", "reason", "file"],
      "additionalProperties": false,
      "properties": {
        "category": { "type": "string" },
        "title": { "type": "string" },
        "reason": { "type": "string" },
        "file": { "type": ["string", "null"] },
        "line": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "1-based line when the heuristic knows it (added in 1.1); lets consumers deep-link."
        }
      }
    }
  }
}
